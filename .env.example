# PostgreSQL 설정 (로컬 또는 Supabase 이외 환경용)
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_DB=chatbot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Supabase 연결 (Supabase 사용 시 활성화)
# Supabase 프로젝트에서 제공하는 연결 문자열
# 형식: postgresql://postgres:[password]@[host]:[port]/[database]?sslmode=require
# 또는 Supabase 대시보드의 Database > Connection string > URI 복사
DATABASE_URL=
DATABASE_URL_LEGACY=postgresql+psycopg2://chatbot:chatbot@postgres:5432/chatbot

OPENAI_API_KEY=your_openai_api_key