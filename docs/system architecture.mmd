config:
  layout: fixed
---
flowchart TB
    A["사용자 질문 입력"] --> B["카카오 챗봇 API 수신"]
    B --> C["FastAPI 백엔드 진입"]
    C --> D["입력 검증 / 전처리"] & L1[("질의 로그 저장")]

    D --> E["1차 상위 분류<br>규칙 기반"]
    E -- 일반 대화 --> F["일반 대화 상세 분류<br>규칙 기반"]
    F --> G["규칙 기반 응답 생성"] & n1["인사<br>감정 표현<br>감사 / 반응<br>챗봇 관련 질문"]
    G --> H["응답 검증 / 후처리"]
    H --> I["카카오 응답 포맷 변환"]
    I --> J["사용자에게 최종 응답 반환"]

    E -- 정보성 질문 --> K["정보성 카테고리 분류<br>규칙 기반"]
    K -. 분류 완료 .-> UserScopeStart
    UserScopeStart["사용자 작업 범위 시작<br>(엔티티 추출 이후)"] --> M["엔티티 추출"]

    M --> N["Query 재작성 / 정규화"] & n5["핵심 키워드 추출"]
    N --> O["검색 전략 결정"]
    O --> P["카테고리 우선 Hybrid Search"] & n3["1. 검색 범위<br>2. 검색 방식<br>3. 가중치 조정<br>4. top-k 개수<br>5. fallback 여부"]
    P --> L2[("검색 로그 저장")] & X{"검색 결과 충분한가?"}

    X -- 예 --> Q["후보 문서 수집"]
    X -- 아니오 --> Y["전체 범위 Hybrid Search fallback"]
    Y --> Q

    Q --> R["Re-ranking"]
    R --> S["상위 문서 선택"]
    S --> T["Context 압축 / 조합"]
    T --> U["프롬프트 구성"]
    U --> V["LLM 응답 생성"]
    V --> L3[("응답 로그 저장")] & W["응답 검증 / 후처리"]
    W --> I

    n3 --> n4["카테고리: 일정/공지<br>검색: 공지 문서만<br>가중치: 최신 문서 우선<br>top-k: 5<br>fallback: 전체 검색 허용"]
    n5 --> n6["예시 질문: 중앙도서관 주말에도 열어?<br><br>시설: 중앙도서관<br>조건: 주말<br>의도: 운영시간"]

    style UserScopeStart fill:#fff3cd,stroke:#d39e00,stroke-width:2px,color:#222
